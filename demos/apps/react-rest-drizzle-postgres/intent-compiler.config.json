{
  "$schema": "https://intent-compiler.dev/schemas/config-v1.json",
  "version": 1,
  "project": {
    "name": "react-rest-drizzle-postgres",
    "description": "Full-stack TypeScript demo with AOT natural-language intent compilation."
  },
  "onboarding": {
    "selectedFrameworks": true,
    "allowFrameworkSwitching": false
  },
  "compiler": {
    "mode": "aot",
    "persistedQueries": true,
    "dynamicTemplateParameterization": true,
    "frameworkResolution": "manual"
  },
  "frameworks": {
    "llmProvider": "openai",
    "database": "postgresql",
    "orm": "drizzle",
    "apiArchitecture": "rest"
  },
  "env": {
    "databaseUrl": "DATABASE_URL",
    "apiKey": "OPENAI_API_KEY"
  }
}
