{
  "name": "intent-compiler",
  "version": "0.1.0",
  "description": "AOT intent compiler scaffolding for natural-language database workflows.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "bin": {
    "intent-compiler": "./dist/bin/intent-compiler.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node -e \"import('node:fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/test/**/*.test.js",
    "prepack": "npm run build"
  },
  "keywords": [
    "nl2sql",
    "intent",
    "compiler",
    "llm",
    "orm"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "typescript": "^5.8.3"
  }
}
